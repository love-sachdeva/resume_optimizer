{
  "name": "thankyoulove",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "build": "node scripts/next-build-retry.mjs",
    "build:once": "next build",
    "rebuild": "npm run clean && npm run build",
    "prestart": "node -e \"const fs=require('fs');const p=require('path');const d=p.join('.next');for(const f of ['BUILD_ID','prerender-manifest.json']){try{fs.accessSync(p.join(d,f));}catch{console.error('\\nIncomplete or missing .next output (expected '+f+'). Run `npm run build` before `npm start`.\\n');process.exit(1);}}\"",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "framer-motion": "^12.11.0",
    "jspdf": "^3.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.8.0",
    "next": "^15.3.2",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
